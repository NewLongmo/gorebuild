APP_ENV=production
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT_SECONDS=15
HTTP_WRITE_TIMEOUT_SECONDS=30
HTTP_IDLE_TIMEOUT_SECONDS=60
HTTP_SHUTDOWN_TIMEOUT_SECONDS=10
HTTP_BODY_LIMIT_MB=4
HTTP_PREFORK=false
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8081

AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_TOKEN_TTL_HOURS=24

MYSQL_ROOT_PASSWORD=replace-root-password
MYSQL_DATABASE=dw0rdwk
MYSQL_USER=dw0rdwk
MYSQL_PASSWORD=replace-app-db-password
MYSQL_PORT=3306
MYSQL_MAX_OPEN_CONNS=64
MYSQL_MAX_IDLE_CONNS=16
MYSQL_CONN_MAX_LIFETIME_MINUTES=30
MYSQL_CONN_MAX_IDLE_MINUTES=5

DB_AUTO_MIGRATE=true
DB_SEED_DEFAULTS=true
BOOTSTRAP_ADMIN_ACCOUNT=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-initial-admin-password
BOOTSTRAP_ADMIN_NAME=Administrator

REDIS_PREFIX=dw0rdwk:
REDIS_ENABLED=true
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=32
REDIS_MIN_IDLE_CONNS=8
REDIS_DIAL_TIMEOUT_MS=2000
REDIS_READ_TIMEOUT_MS=1000
REDIS_WRITE_TIMEOUT_MS=1000
REDIS_POOL_TIMEOUT_MS=2000

ORDER_WORKER_ENABLED=true
ORDER_WORKER_CONCURRENCY=2
ORDER_WORKER_MAX_ATTEMPTS=3
ORDER_WORKER_RETRY_DELAY_MS=1000
ORDER_QUEUE_RECOVER_ON_START=true
ORDER_QUEUE_RECOVERY_BATCH_SIZE=500
